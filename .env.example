# MongoDB Connection
# Replace with your actual MongoDB connection string
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
# For Local MongoDB: mongodb://localhost:27017/dbname
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/albahargroup
MONGODB_DB=albahargroup

# Admin Authentication (required for /admin/dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_AUTH_SECRET=change-me-long-random-secret
ADMIN_EMAIL=admin@albahargroup.com

# Cache revalidation (On-Demand ISR)
REVALIDATE_SECRET=change-me-long-random-secret

# Email Configuration (if needed)
EMAIL_USER=example@gmail.com
